{
  "name": "@plantbase/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cli:build": "nx build cli",
    "cli": "tsx --conditions=@plantbase/source apps/cli/src/main.ts",
    "db:generate": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=packages/db/prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio --schema=packages/db/prisma/schema.prisma"
  },
  "private": true,
  "prisma": {
    "seed": "tsx packages/db/prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/esbuild": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/node": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/vitest": "23.0.1",
    "@nx/web": "23.0.1",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "~4.1.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jiti": "2.4.2",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "23.0.1",
    "prettier": "^3.8.1",
    "prisma": "^6",
    "tslib": "^2.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {
    "@prisma/client": "^6"
  }
}
